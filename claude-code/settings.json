{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$HOME/.config\" && [ -n \"$(git status --porcelain -uno -- claude-code)\" ] && git commit -q -m \"claude-code: auto-sync claude config\" -- claude-code && git push -q origin main; true",
            "async": true,
            "timeout": 30,
            "statusMessage": "Syncing claude config to dotfiles"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bun x ccusage statusline",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "preferredNotifChannel": "terminal_bell",
  "feedbackSurveyState": {
    "lastShownTime": 1754078592851
  },
  "agentPushNotifEnabled": true
}

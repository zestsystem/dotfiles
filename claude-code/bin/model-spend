#!/usr/bin/env bash
# Per-model Claude + Codex usage from local transcripts (via ccusage).
#
# HONEST SCOPE: local transcripts record token counts and service_tier (speed),
# but NOT billing attribution — there is no sub-vs-credit flag in the data, and
# no public API for consumer credit balance. So this tool reports API-EQUIVALENT
# VALUE only (what the tokens would cost at API rates). It cannot and does not
# claim what Anthropic actually billed you. For real credit dollars, the single
# source of truth is Anthropic Console > Settings > Usage.
#
# What it CAN do: flag lanes that model-economics.json marks credit-billable, and
# show their API-equivalent value as a credit-EXPOSURE CEILING (actual is ≤ this,
# since subscription may still cover part). No date math fabricating a dollar bill.
#
# Usage: model-spend [DAYS]   (default 7)
set -uo pipefail
export PATH="$HOME/.local/bin:/etc/profiles/per-user/$USER/bin:/run/current-system/sw/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

DAYS="${1:-7}"
SINCE=$(date -v-"$DAYS"d +%Y%m%d)

npx -y ccusage@latest daily --since "$SINCE" --json 2>/dev/null | DAYS="$DAYS" node -e '
const fs = require("fs");
const days = (JSON.parse(fs.readFileSync(0, "utf8")).daily) || [];

let econ = null;
try { econ = JSON.parse(fs.readFileSync(process.env.HOME + "/.claude/model-economics.json", "utf8")); } catch {}

// longest-prefix lane match; returns the lane so we can read its credit flag/note
function laneFor(model) {
  if (!econ) return null;
  let best = null;
  for (const lane of econ.lanes || []) {
    const id = (lane.model || "").split(" ")[0];
    if (id && model.startsWith(id) && (!best || id.length > best.idLen)) best = { lane, idLen: id.length };
  }
  return best?.lane ?? null;
}

const agg = {};
for (const day of days)
  for (const m of day.modelBreakdowns || []) {
    const model = m.modelName;
    agg[model] = agg[model] || { value: 0, out: 0, cacheRead: 0, input: 0, cacheCreate: 0 };
    agg[model].value += m.cost || 0;
    agg[model].out += m.outputTokens || 0;
    agg[model].cacheRead += m.cacheReadTokens || 0;
    agg[model].input += m.inputTokens || 0;
    agg[model].cacheCreate += m.cacheCreationTokens || 0;
  }

// ccusage has no pricing entry for some models (e.g. gateway-routed k3) and
// silently reports cost=0 despite real token counts. When that happens and
// the model has a priced lane in model-economics.json, price it from there
// instead of showing a misleading $0.00.
const estimated = new Set();
for (const [model, v] of Object.entries(agg)) {
  if (v.value > 0) continue;
  if (!(v.out || v.cacheRead || v.input || v.cacheCreate)) continue;
  const lane = laneFor(model);
  const rate = lane && lane.api_usd_per_mtok;
  if (!rate) continue;
  const cacheReadRate = rate.cache_read ?? rate.in;
  const cacheCreateRate = rate.cache_write ?? rate.in;
  v.value = (v.input * rate.in + v.cacheRead * cacheReadRate + v.cacheCreate * cacheCreateRate + v.out * rate.out) / 1e6;
  estimated.add(model);
}

const rows = Object.entries(agg).sort((a, b) => b[1].value - a[1].value);
const fmt = (n) => "$" + n.toFixed(2);
let total = 0;
const creditNotes = [];

console.log(`Per-model API-equivalent value, last ${process.env.DAYS} day(s)  (local transcripts via ccusage)`);
console.log("Value = what these tokens cost at API rates. NOT a bill — see note below.\n");
console.log("model".padEnd(28) + "API-equiv $".padStart(13) + "credit?".padStart(9) + "  out-tok".padStart(10) + "  cache-read".padStart(13));
for (const [model, v] of rows) {
  total += v.value;
  const lane = laneFor(model);
  const creditable = !!(lane && lane.credit_billable);
  if (creditable) creditNotes.push({ model, value: v.value, status: lane.credit_status || "" });
  console.log(
    (model + (estimated.has(model) ? "*" : "")).padEnd(28) +
    fmt(v.value).padStart(13) +
    (creditable ? "MAYBE" : "no").padStart(9) +
    ((v.out / 1e6).toFixed(1) + "M").padStart(10) +
    ((v.cacheRead / 1e6).toFixed(0) + "M").padStart(13)
  );
}
console.log("-".repeat(73));
console.log("TOTAL".padEnd(28) + fmt(total).padStart(13));
if (estimated.size) {
  console.log(`\n* ccusage has no pricing data for this model — value estimated from model-economics.json lane rates instead (snapshot, may drift from current upstream pricing).`);
}

console.log("");
if (creditNotes.length) {
  console.log("CREDIT EXPOSURE (may bill real money — verify actual $ in Console > Settings > Usage):");
  for (const n of creditNotes)
    console.log(`  ${n.model}: up to ${fmt(n.value)} API-equiv over window is credit-ELIGIBLE (actual ≤ this; sub may cover part).` + (n.status ? `\n    status: ${n.status}` : ""));
  console.log("  Local transcripts carry NO sub-vs-credit flag — Console is the only authoritative bill.");
} else {
  console.log("No credit-billable lanes flagged in model-economics.json. All value shown is subscription-covered.");
  console.log("(If Anthropic changes what bills to credits, set credit_billable + credit_status on that lane — no code change.)");
}
'
